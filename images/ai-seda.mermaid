graph LR
    style INGEST fill:#45B7D1,color:#000
    style IDX fill:#4ECDC4,color:#000
    style RETR fill:#96CEB4,color:#000
    style GEN fill:#FFEAA7,color:#000
    style VAL fill:#FF8C42,color:#000
    style AUDIT fill:#DDA0DD,color:#000

    INGEST[Documents\nWorkflow Actor\ncheckpoint each stage] --> IDX[Index Stage\nIndexerActor\nKV store]
    IDX --> RETR[Retrieve Stage\nRetrieverActor\nkeyword + deep search]
    RETR --> GEN[Generate Stage\nGeneratorActor\ncircuit breaker]
    GEN --> VAL[Validate Stage\nValidatorActor\nlength + grounding + safety]
    GEN -.->|fire-and-forget| AUDIT[Audit Stage\nPipelineEventActor\nGenEvent]
