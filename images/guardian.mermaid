graph TD
    Sup[Guardian Supervisor<br/>one_for_one] -->|monitors| LLM[LLMRouterActor]
    Sup -->|monitors| Tools[ToolRegistryActor]
    Sup -->|monitors| Agent[AgentActor]
    Sup -->|monitors| Session[SessionManagerActor]
    Sup -->|monitors| Orch[OrchestratorActor]
    Sup -->|monitors| Memory[MemoryActor]
    Sup -->|monitors| Audit[AuditEventActor]
    Sup -->|monitors| FSM[AgentStateFSM]
    Sup -->|monitors| TaskQ[TaskQueueActor]
    Sup -->|monitors| Health[HealthMonitorActor]

    LLM -.->|CRASH| Sup
    Sup -.->|restart only LLM| LLM2[LLMRouterActor<br/>restarted, clean state]

    style Sup fill:#D32F2F,color:#fff,stroke:#B71C1C,stroke-width:3px
    style LLM fill:#E57373,color:#fff,stroke:#C62828,stroke-width:2px,stroke-dasharray: 5 5
    style LLM2 fill:#2E7D32,color:#fff,stroke:#1B5E20,stroke-width:2px
    style Tools fill:#1565C0,color:#fff,stroke:#0D47A1
    style Agent fill:#1565C0,color:#fff,stroke:#0D47A1
    style Session fill:#1565C0,color:#fff,stroke:#0D47A1
    style Orch fill:#1565C0,color:#fff,stroke:#0D47A1
    style Memory fill:#1565C0,color:#fff,stroke:#0D47A1
    style Audit fill:#1565C0,color:#fff,stroke:#0D47A1
    style FSM fill:#1565C0,color:#fff,stroke:#0D47A1
    style TaskQ fill:#1565C0,color:#fff,stroke:#0D47A1
    style Health fill:#1565C0,color:#fff,stroke:#0D47A1
